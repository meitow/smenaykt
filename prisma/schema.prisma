generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique
  accessToken String   @unique
  phone       String
  tasks       Task[]
  createdAt   DateTime @default(now())
}

model UserProfile {
  phone              String    @id
  name               String    @default("")
  avatarUrl          String?
  bio                String    @default("")
  identityVerified   Boolean   @default(false)
  identityVerifiedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  identityDocuments  IdentityDocument[]
}

model Task {
  id            String    @id @default(cuid())
  source        String    // person | partner
  storeId       String?
  store         Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  title         String
  description   String    @default("")
  pay           Int
  place         String
  timeLabel     String
  scheduledAt   DateTime?
  category      String    @default("personal")
  durationHours Int       @default(2)
  emoji         String    @default("📋")
  lmkRequired   Boolean   @default(false)
  phone         String
  status        String    @default("OPEN") // OPEN | ACCEPTED | DONE
  workerName    String?
  workerPhone   String?
  acceptedAt    DateTime?
  publisherCompletedAt DateTime?
  workerCompletedAt    DateTime?
  completedAt   DateTime?
  hidden        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  reviews       Review[]
  messages      TaskMessage[]
  chatReads     TaskChatReadState[]

  @@index([phone])
  @@index([workerPhone])
  @@index([status, createdAt])
}

model Review {
  id            String   @id @default(cuid())
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewerPhone String
  revieweePhone String
  rating        Int
  comment       String   @default("")
  createdAt     DateTime @default(now())

  @@unique([taskId, reviewerPhone])
  @@index([revieweePhone, createdAt])
}

model Notification {
  id             String    @id @default(cuid())
  recipientPhone String
  taskId         String
  type           String // counterparty_completed | task_closed
  title          String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([recipientPhone, readAt, createdAt])
}

model BannedPhone {
  phone     String   @id
  reason    String   @default("")
  bannedBy  String   @default("")
  createdAt DateTime @default(now())
}

model ModeratorPhone {
  phone     String   @id
  name      String   @default("")
  addedBy   String   @default("")
  createdAt DateTime @default(now())
}

model TaskMessage {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  senderType String   // user | partner
  senderId   String
  body       String
  createdAt  DateTime @default(now())

  @@index([taskId, createdAt])
}

model TaskChatReadState {
  id              String   @id @default(cuid())
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  participantType String   // user | partner
  participantId   String
  lastReadAt      DateTime @default(now())

  @@unique([taskId, participantType, participantId])
  @@index([participantType, participantId])
}

model IdentityDocument {
  id              String   @id @default(cuid())
  phone           String
  profile         UserProfile @relation(fields: [phone], references: [phone], onDelete: Cascade)
  status          String   @default("pending") // pending | approved | rejected
  storageKey      String
  storageBackend  String   @default("local") // local | s3
  mimeType        String
  fileSize        Int
  consentAt       DateTime
  reviewedAt      DateTime?
  reviewedBy      String   @default("")
  rejectReason    String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([phone, createdAt])
  @@index([status, createdAt])
}
