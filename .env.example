# Copy to .env on a new machine
DATABASE_URL="file:./dev.db"

# Comma-separated moderator phones (synced to DB on first access)
MODERATOR_PHONES="+79991234567"

# Owner key for /admin (field «Ключ владельца» or /admin?secret=...)
ADMIN_SECRET="change-me-before-production"

# Optional support links in profile
NEXT_PUBLIC_SUPPORT_TELEGRAM="https://t.me/smenaykt"
NEXT_PUBLIC_SUPPORT_EMAIL="support@smenaykt.ru"

# Private file storage (passports). Default: local folder on server.
PRIVATE_STORAGE_BACKEND="local"
PRIVATE_STORAGE_LOCAL_DIR="./private-uploads"

# Future S3-compatible storage (not wired yet — set backend to local until configured):
# PRIVATE_STORAGE_BACKEND="s3"
# PRIVATE_STORAGE_S3_BUCKET=""
# PRIVATE_STORAGE_S3_REGION=""
# PRIVATE_STORAGE_S3_ACCESS_KEY=""
# PRIVATE_STORAGE_S3_SECRET_KEY=""
